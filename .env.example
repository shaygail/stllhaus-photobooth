# Copy to `.env.local` and edit. Restart `npm run dev` / `npm run dev:lan` after changes.
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# --- Booth lock (`/booth` + creating digital slips) — required for public deploy ---
# Staff sign in at `/login`. Guest `/digital/…` QR pages stay public (no password).
# Use a long random password in production.
BOOTH_PASSWORD=
# Optional: separate secret for signing the session cookie (defaults to a hash of BOOTH_PASSWORD)
# BOOTH_SESSION_SECRET=

# --- Phone QR / digital keepsake (`/digital/…` — view & download JPEG, no camera) ---
# The phone must open the **same host** as this Next server (your Mac’s LAN URL), not
# `localhost` (that would load the phone’s own empty app). HTTP is fine for the image
# page; the **booth camera** on `/booth` still needs HTTPS on a LAN IP (`npm run dev:lan`).
# 1. Run: npm run dev:lan
# 2. Find your Mac’s Wi‑Fi IP (System Settings → Network → Wi‑Fi → Details)
# 3. Set this to that https URL, no trailing slash (same port Next prints, usually 3000)
#
# Example:
# NEXT_PUBLIC_BOOTH_PUBLIC_URL=https://192.168.1.15:3000
NEXT_PUBLIC_BOOTH_PUBLIC_URL=

# --- Vercel Blob (production receipt / digital-slip persistence) ---
# Without this, slips live only in server memory — receipt QR links often 404 on Vercel.
# Create a Blob store in the Vercel dashboard and add the read-write token here (and in Vercel env).
# BLOB_READ_WRITE_TOKEN=

# Optional: fixed port for `next dev`
# PORT=3000
